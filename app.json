{
  "expo": {
    "name": "LifeDrop",
    "slug": "lifedrop-app",
    "version": "1.0.0",
   
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.lakshya.lifedrop"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "caa19b98-612b-457c-8059-1ff10fb9b775"
      }
    },
    "owner": "rishabv894",
    "plugins": [
      "expo-font",
      "expo-router"
    ]
  }
}
